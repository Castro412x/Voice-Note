rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Only authenticated users can access storage
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users can only access their own audio files
    // Path: users/{userId}/notes/{noteId}/audio.webm
    match /users/{userId}/notes/{noteId}/audio.webm {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024  // < 10 MB
        && request.resource.contentType.matches('audio/webm');
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
